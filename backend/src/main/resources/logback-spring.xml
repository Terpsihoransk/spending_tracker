<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="spending-tracker-backend"/>
    <springProperty scope="context" name="appTimezone" source="app.timezone" defaultValue="UTC"/>

    <!-- Консольный appender с локальным временем -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS, Asia/Novosibirsk} [%level] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- UDP Appender для Graylog -->
    <appender name="GRAYLOG_UDP" class="net.logstash.logback.appender.LogstashUdpSocketAppender">
        <destination>${GRAYLOG_HOST:-localhost}:${GRAYLOG_PORT:-12201}</destination>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"app_name":"${appName}","environment":"production","timezone":"Asia/Novosibirsk"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <message>message</message>
                <logger>logger</logger>
                <level>level</level>
                <thread>thread</thread>
                <mdc>mdc</mdc>
            </fieldNames>
        </encoder>
    </appender>

    <!-- Async wrapper -->
    <appender name="ASYNC_GRAYLOG" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="GRAYLOG_UDP"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
    </appender>

    <!-- HTTP логгер - только в Graylog -->
    <logger name="HTTP" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_GRAYLOG"/>
    </logger>

    <!-- Root логгер -->
    <springProfile name="default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_GRAYLOG"/>
        </root>
        <logger name="spending.tracker.backend.filter" level="OFF"/>
        <logger name="spending.tracker.backend.config.EmailAuthenticationFilter" level="WARN"/>
        <logger name="org.springframework.web" level="WARN"/>
    </springProfile>

    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>